# Files NOT to upload to Cloud Build when running `gcloud run deploy --source .`
# Without this, every build uploads node_modules + reports + .next, blowing
# up upload size and risking secrets in .env reaching Cloud Build logs.

# Defer to .gitignore for the common Python / Node noise.
#!include:.gitignore

# Local-only / never-ship-to-Cloud-Build
.env
.env.*
!.env.example

# Frontend source IS needed: the multi-stage Dockerfile builds the Next.js
# console (stage 1) and FastAPI serves it from the same container. We only
# exclude the heavy/build-output dirs (handled below + via .gitignore:
# node_modules/, .next/, out/), not the source.
frontend/node_modules/
frontend/.next/
frontend/out/

# Tests, docs, scripts that don't run in production.
tests/
docs/

# Local artifacts
reports/*.json
reports/*.md
!reports/.gitkeep
requirements.lock

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Git itself (Cloud Build doesn't need history)
.git/
.gitignore
.github/
