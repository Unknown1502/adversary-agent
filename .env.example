# =========================================================================
# Adversary — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# =========================================================================

# --- Gemini / Vertex AI ---
# Use Vertex AI as the Gemini backend (required by the hackathon track).
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Model identifiers. Confirmed available on Vertex AI in us-central1
# (project adversary-agent, 2026-06). If you see 404 NOT_FOUND, re-check the
# exact ids in the Vertex AI Model Garden for your project/region.
MODEL_PRO=gemini-2.5-pro
MODEL_FLASH=gemini-2.5-flash

# --- Arize Phoenix (cloud or self-hosted) ---
# Cloud endpoint default; replace with your self-hosted URL or your Phoenix
# Cloud space URL (e.g. https://app.phoenix.arize.com/s/<your-space>).
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
# Get this from Phoenix → Settings → API Keys. NEVER commit a real key.
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_PROJECT_NAME=adversary

# --- Campaign tuning ---
# Which target build the orchestrator should attack by default.
TARGET_AGENT=vulnerable
# Hard cap on attempts per attack class before declaring the class done.
MAX_ATTEMPTS_PER_CLASS=4

# --- API / hosting ---
# Where the FastAPI process binds. Cloud Run injects PORT=8080.
PORT=8080
# Comma-separated CORS origins for the frontend.
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Reports ---
# Directory where the Reporter writes per-campaign scorecards + markdown.
REPORTS_DIR=./reports

# --- Frontend ---
# Public URL of the FastAPI backend, read by the Next.js console at
# build time. In dev, leave unset — the console defaults to localhost:8080.
# In Cloud Run, set this to the hosted backend URL before `npm run build`.
NEXT_PUBLIC_API_BASE=http://localhost:8080
